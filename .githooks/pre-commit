#!/bin/sh
# Regenerates the project structure tree and updates readme.md / readme.uk.md
# before every commit.

powershell.exe -NoProfile -ExecutionPolicy Bypass -File "scripts/generate_structure.ps1"
if [ $? -ne 0 ]; then
    echo "ERROR: generate_structure.ps1 failed" >&2
    exit 1
fi

git add readme.md readme.uk.md scripts/structure.txt
