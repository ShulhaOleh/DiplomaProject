<Window x:Class="Clinic.View.Admin.EditUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="{DynamicResource EditUser_Title}"
        Height="360" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Логін -->
            <RowDefinition Height="Auto"/>
            <!-- Роль -->
            <RowDefinition Height="Auto"/>
            <!-- Прізвище -->
            <RowDefinition Height="Auto"/>
            <!-- Ім’я -->
            <RowDefinition Height="Auto"/>
            <!-- По батькові -->
            <RowDefinition Height="Auto"/>
            <!-- Телефон -->
            <RowDefinition Height="Auto"/>
            <!-- Пароль -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- 0: Login -->
        <TextBlock Text="{DynamicResource Label_Login}" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="UsernameBox"
                 Grid.Row="0"
                 Margin="100,0,0,10"
                 Width="280"/>

        <!-- 1: Role -->
        <TextBlock Text="{DynamicResource Label_Role}" Grid.Row="1" VerticalAlignment="Center"/>
        <ComboBox x:Name="RoleBox"
                  Grid.Row="1"
                  Margin="100,0,0,10"
                  Width="280"
                  SelectionChanged="RoleBox_SelectionChanged">
            <ComboBoxItem Content="Doctor"/>
            <ComboBoxItem Content="Receptionist"/>
        </ComboBox>

        <!-- 2: Last name -->
        <TextBlock Text="{DynamicResource Label_LastName}" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBox x:Name="LastNameBox"
                 Grid.Row="2"
                 Margin="100,0,0,10"
                 Width="280"/>

        <!-- 3: First name -->
        <TextBlock Text="{DynamicResource Label_FirstName}" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBox x:Name="FirstNameBox"
                 Grid.Row="3"
                 Margin="100,0,0,10"
                 Width="280"/>

        <!-- 4: Father's name -->
        <TextBlock Text="{DynamicResource Label_FathersName}" Grid.Row="4" VerticalAlignment="Center"/>
        <TextBox x:Name="FathersNameBox"
                 Grid.Row="4"
                 Margin="100,0,0,10"
                 Width="280"/>

        <!-- 5: Phone (masked) -->
        <TextBlock Text="{DynamicResource PhoneLabel}" Grid.Row="5" VerticalAlignment="Center"/>
        <xctk:MaskedTextBox x:Name="PhoneBox"
                            Grid.Row="5"
                            Margin="100,0,0,10"
                            Width="280"
                            Mask="+380 (00) 000-0000"
                            PromptChar="_"
                            Value="{Binding Phone, Mode=TwoWay}"
                            Watermark=" +380 (__) ___-____"/>

        <!-- 6: Password -->
        <TextBlock x:Name="PasswordLabel"
                   Text="{DynamicResource PasswordLabel}"
                   Grid.Row="6"
                   VerticalAlignment="Center"/>
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="6"
                     Margin="100,0,0,10"
                     Width="280"/>

        <!-- 7: Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Save}"
                    Width="100"
                    Margin="0,10,10,0"
                    Click="Save_Click"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="100"
                    Margin="0,10,0,0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
