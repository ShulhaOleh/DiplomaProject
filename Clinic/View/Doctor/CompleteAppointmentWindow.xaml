<Window x:Class="Clinic.View.Doctor.CompleteAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CompleteAppointment_Title}" Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <ScrollViewer>
        <StackPanel Margin="20" VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                <Button Content="{DynamicResource Btn_PatientNoShow}" Click="NoShow_Click" Width="180" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Btn_StartAppointment}" Click="EnableEditing_Click" Width="180" Background="LightGreen"/>
            </StackPanel>

            <GroupBox Header="{DynamicResource Group_Patient}" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock x:Name="PatientNameText" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{DynamicResource Label_CardNumber}"/>
                    <TextBlock x:Name="CardNumberText" FontStyle="Italic"/>
                    <TextBlock Text="{DynamicResource Label_BloodType}"/>
                    <ComboBox x:Name="BloodTypeComboBox" Width="100">
                        <ComboBoxItem Content="A+" />
                        <ComboBoxItem Content="A-" />
                        <ComboBoxItem Content="B+" />
                        <ComboBoxItem Content="B-" />
                        <ComboBoxItem Content="AB+" />
                        <ComboBoxItem Content="AB-" />
                        <ComboBoxItem Content="O+" />
                        <ComboBoxItem Content="O-" />
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Group_Allergies}" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <ListBox x:Name="AllergyList" Height="80"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="NewAllergyBox" Width="200"/>
                        <Button x:Name="AddAllergyButton" Content="{DynamicResource Btn_Add}" Width="80" Margin="10,0,0,0" Click="AddAllergy_Click"/>
                        <Button x:Name="RemoveAllergyButton" Content="{DynamicResource Btn_Remove}" Width="80" Margin="10,0,0,0" Click="RemoveAllergy_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Group_ChronicDiseases}" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <ListBox x:Name="DiseaseList" Height="80"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="NewDiseaseBox" Width="200"/>
                        <Button x:Name="AddDiseaseButton" Content="{DynamicResource Btn_Add}" Width="80" Margin="10,0,0,0" Click="AddDisease_Click"/>
                        <Button x:Name="RemoveDiseaseButton" Content="{DynamicResource Btn_Remove}" Width="80" Margin="10,0,0,0" Click="RemoveDisease_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="{DynamicResource Label_AppointmentNotes}" FontWeight="SemiBold"/>
            <TextBox x:Name="NotesBox" AcceptsReturn="True" Height="120" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{DynamicResource Btn_SaveAndClose}" Click="Complete_Click" Width="200" Background="LightGreen"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
